{
  "name": "goapp-server",
  "version": "2.1.0",
  "description": "GoApp Ride Matching Platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:dev": "NODE_ENV=development node server.js",
    "start:test": "NODE_ENV=test node server.js",
    "start:prod": "NODE_ENV=production node server.js",
    "dev:seed-drivers": "node scripts/dev-seed-drivers.js",
    "dev:reset-test-data": "node scripts/dev-reset-test-data.js",
    "dev:reset-test-data:dry-run": "node scripts/dev-reset-test-data.js --dry-run true",
    "docker:setup": "bash scripts/setup-docker.sh",
    "docker:up": "bash scripts/docker-up.sh",
    "docker:down": "docker compose down",
    "docker:logs:api": "docker logs -f --tail=200 goapp-api",
    "docker:logs:api:compose": "docker compose logs -f --tail=200 api",
    "docker:logs:api:errors": "bash -lc 'docker logs --since=10m goapp-api | (rg -i \"error|warn|exception|timeout\" || grep -Ei \"error|warn|exception|timeout\")'",
    "docker:ps:api": "docker ps --filter \"name=goapp-api\"",
    "support:db:apply": "bash scripts/apply-support-db.sh",
    "api": "node server.js --api-only",
    "projection:backfill": "node scripts/backfill/backfill-domain-projections.js",
    "check:projections": "node scripts/consistency-checks/check-domain-projections.js",
    "domain:plan": "node migrations/domain-split/plan-domain-extraction.js",
    "domain:extract:dry-run": "node migrations/domain-split/run-domain-extraction.js",
    "domain:extract": "node migrations/domain-split/run-domain-extraction.js --execute true",
    "domain:bootstrap:dry-run": "node migrations/domain-split/bootstrap-domain-split.js --dry-run true",
    "domain:bootstrap": "node migrations/domain-split/bootstrap-domain-split.js",
    "domain:verify:schema": "node migrations/domain-split/verify-domain-extraction.js --schema-only true",
    "domain:verify": "node migrations/domain-split/verify-domain-extraction.js",
    "check:architecture": "node scripts/check-architecture.js",
    "check:secrets": "node scripts/check-secrets.js",
    "check:ci": "npm run check:architecture && npm run check:secrets",
    "test": "npm run test:integration",
    "test:unit": "echo \"Unit/mock tests removed. Use npm run test:integration\"",
    "test:integration": "npm run test:integration:base && npm run test:dev-verification",
    "test:integration:all": "NODE_ENV=test node --require ./config/env-loader.js --test --test-force-exit tests/integration/*.test.js",
    "test:integration:base": "NODE_ENV=test node --require ./config/env-loader.js --test --test-force-exit tests/integration/db.integration.test.js tests/integration/dev-reset-service.integration.test.js tests/integration/matching-engine-dev.integration.test.js tests/integration/redis.integration.test.js tests/integration/refresh-token-security.integration.test.js tests/integration/response-envelope.integration.test.js tests/integration/trip-share.integration.test.js",
    "test:dev-verification": "node scripts/run-dev-verification.js",
    "docs:db-schema": "node scripts/generate-db-schema-doc.js"
  },
  "dependencies": {
    "@googlemaps/google-maps-services-js": "^3.4.0",
    "dotenv": "^17.3.1",
    "firebase-admin": "^12.1.0",
    "kafkajs": "^2.2.4",
    "pg": "^8.20.0",
    "redis": "^5.11.0"
  }
}
