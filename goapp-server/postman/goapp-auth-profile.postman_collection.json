{
  "info": {
    "name": "GoApp Auth + Profile",
    "_postman_id": "4f086764-a573-4510-90d8-dd98bbdd4a19",
    "description": "Tested auth and profile flow for GoApp backend. Request OTP, optionally resend OTP, log in with the latest requestId, create profile, then fetch profile.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "phone", "value": "9876543210" },
    { "key": "countryCode", "value": "+91" },
    { "key": "otp", "value": "123456" },
    { "key": "requestId", "value": "" },
    { "key": "accessToken", "value": "" },
    { "key": "name", "value": "Yogesh S" },
    { "key": "gender", "value": "Male" },
    { "key": "dateOfBirth", "value": "12 July 1985" },
    { "key": "email", "value": "yogesh1212@gmail.com" },
    { "key": "emergencyContact", "value": "9876543210" }
  ],
  "item": [
    {
      "name": "Request OTP",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('OTP request succeeded', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const body = pm.response.json();",
              "if (body && body.data && body.data.requestId) {",
              "  pm.collectionVariables.set('requestId', body.data.requestId);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"phone\": \"{{phone}}\",\n  \"countryCode\": \"{{countryCode}}\",\n  \"channel\": \"sms\"\n}"
        },
        "url": "{{baseUrl}}/api/v1/auth/request-otp"
      }
    },
    {
      "name": "Resend OTP",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Resend OTP succeeded', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const body = pm.response.json();",
              "if (body && body.data && body.data.requestId) {",
              "  pm.collectionVariables.set('requestId', body.data.requestId);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"phone\": \"{{phone}}\",\n  \"countryCode\": \"{{countryCode}}\"\n}"
        },
        "url": "{{baseUrl}}/api/v1/auth/resend-otp"
      }
    },
    {
      "name": "Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Login succeeded', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const body = pm.response.json();",
              "if (body && body.data && body.data.accessToken) {",
              "  pm.collectionVariables.set('accessToken', body.data.accessToken);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"phone\": \"{{phone}}\",\n  \"countryCode\": \"{{countryCode}}\",\n  \"otp\": \"{{otp}}\",\n  \"requestId\": \"{{requestId}}\",\n  \"deviceId\": \"postman-test-device\",\n  \"platform\": \"postman\",\n  \"fcmToken\": \"postman-test-token\"\n}"
        },
        "url": "{{baseUrl}}/api/v1/auth/login"
      }
    },
    {
      "name": "Create Profile",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Profile create succeeded', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"{{name}}\",\n  \"gender\": \"{{gender}}\",\n  \"date_of_birth\": \"{{dateOfBirth}}\",\n  \"email\": \"{{email}}\",\n  \"emergency_contact\": \"{{emergencyContact}}\"\n}"
        },
        "url": "{{baseUrl}}/api/v1/profile/create"
      }
    },
    {
      "name": "Get Profile",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Profile fetch succeeded', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Profile contains DOB and emergency contact', function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body.date_of_birth).to.eql(pm.collectionVariables.get('dateOfBirth'));",
              "  pm.expect(body.emergency_contact).to.eql(pm.collectionVariables.get('emergencyContact'));",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": "{{baseUrl}}/api/v1/profile"
      }
    }
  ]
}
