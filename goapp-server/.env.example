# Runtime
NODE_ENV=production
SERVICE_NAME=goapp-api-gateway
AWS_REGION=ap-south-1

# API server
PORT=3000
WS_PORT=3001

# Event bus (in-memory cap while Kafka integration is staged)
EVENT_BUS_MAX_EVENTS=5000

# Future external services (for enterprise migration)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=goapp
POSTGRES_PASSWORD=goapp
POSTGRES_DB=goapp_enterprise

REDIS_HOST=localhost
REDIS_PORT=6379

KAFKA_BROKERS=localhost:9092

# Admin — CHANGE THIS in production!
GOAPP_ADMIN_TOKEN=goapp-admin-secret

# Security
CORS_ORIGIN=*                  # Restrict to your domain in production, e.g. https://app.goapp.in
MAX_BODY_BYTES=262144           # 256 KB request body limit
SESSION_TTL_MS=86400000         # 24 hours

# Firebase FCM — Push Notifications
# 1. Go to Firebase Console → your project → Project Settings → Service Accounts
# 2. Click "Generate new private key" → download the JSON file
# 3. Copy the values below from that JSON file
FIREBASE_PROJECT_ID=goapp-bf9c7
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@goapp-bf9c7.iam.gserviceaccount.com
