# Runtime
NODE_ENV=development
SERVICE_NAME=goapp-api-gateway
AWS_REGION=ap-south-1

# API server
PORT=3000
WS_PORT=3001

# Event bus (in-memory cap while Kafka integration is staged)
EVENT_BUS_MAX_EVENTS=5000

# Future external services (for enterprise migration)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=goapp
POSTGRES_PASSWORD=goapp
POSTGRES_DB=goapp_identity

REDIS_HOST=localhost
REDIS_PORT=6379

KAFKA_BROKERS=localhost:9092
