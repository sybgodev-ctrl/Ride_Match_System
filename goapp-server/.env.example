# ─── SMS OTP Delivery ────────────────────────────────────────────────────────
# Choose provider: twilio | msg91 | 2factor | console (console = dev mode, logs to terminal)
SMS_PROVIDER=TWOFACTOR

# Twilio (primary — recommended for global numbers)
# Sign up: https://www.twilio.com/try-twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# MSG91 (Indian SMS provider — good for India)
# Sign up: https://msg91.com/
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_SENDER_ID=GOAPP
MSG91_TEMPLATE_ID=your_template_id

# 2Factor (Indian OTP provider)
# Sign up: https://2factor.in/
TWOFACTOR_API_KEY=6f9c0b07-1a3b-11f1-bcb0-0200cd936042

# ─── Coins / Wallet ──────────────────────────────────────────────────────────
COIN_INR_VALUE=0.10       # 1 coin = ₹0.10 discount
COINS_PER_INR_EARN=10     # Earn 1 coin per ₹10 of ride fare
MIN_REDEEM_COINS=10       # Minimum coins needed to redeem
MAX_REDEEM_PCT=0.20       # Max 20% of fare can be discounted via coins

# ─── Database Backend ─────────────────────────────────────────────────────────
# DB_BACKEND=mock  → in-memory MockDb (development default, zero setup required)
# DB_BACKEND=pg    → real PostgreSQL via pg.Pool (required for test/production)
DB_BACKEND=mock
POSTGRES_POOL_MIN=2        # Minimum idle connections in pool
POSTGRES_POOL_MAX=10       # Maximum connections in pool (dev=5, test=3, prod=20)
POSTGRES_SSL=false         # Set true for AWS RDS in production

# ─── Razorpay Payment Gateway ─────────────────────────────────────────────────
# Dashboard: https://dashboard.razorpay.com/app/keys
# Test mode keys start with rzp_test_  — use these for development.
# Live mode keys start with rzp_live_  — use only in production with real money.
#
# Step 1: Create account at https://razorpay.com
# Step 2: Copy Key ID and Key Secret from Dashboard → Settings → API Keys
# Step 3: Create a Webhook in Dashboard → Settings → Webhooks
#          URL: https://your-domain.com/api/v1/payments/webhook
#          Events to subscribe: payment.captured, payment.authorized, payment.failed
#          Copy the webhook secret shown after creation.
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_signing_secret

# ─── Redis Backend ────────────────────────────────────────────────────────────
# REDIS_BACKEND=mock  → in-memory RedisMock (development default, zero setup)
# REDIS_BACKEND=real  → real Redis client (required for test/production)
REDIS_BACKEND=mock

# ─── Driver Document Storage ──────────────────────────────────────────────────
# STORAGE_BACKEND=local  → saves files to local filesystem (development default)
# STORAGE_BACKEND=s3     → AWS S3 (production; extend document-storage-service.js)
STORAGE_BACKEND=local
UPLOAD_DIR=./uploads/driver-docs    # Local directory for file storage
MAX_FILE_SIZE_BYTES=10485760        # 10 MB max per document (images + PDFs)

OTP_SECRET=$(node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")