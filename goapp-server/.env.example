# Runtime
NODE_ENV=development
SERVICE_NAME=goapp-api-gateway
AWS_REGION=ap-south-1

# API server
PORT=3000
WS_PORT=3001

# Event bus (in-memory cap while Kafka integration is staged)
EVENT_BUS_MAX_EVENTS=5000

# Future external services (for enterprise migration)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=goapp
POSTGRES_PASSWORD=goapp
POSTGRES_DB=goapp_identity

REDIS_HOST=localhost
REDIS_PORT=6379

KAFKA_BROKERS=localhost:9092

# Admin — CHANGE THIS in production!
GOAPP_ADMIN_TOKEN=goapp-admin-secret

# Security
CORS_ORIGIN=*                  # Restrict to your domain in production, e.g. https://app.goapp.in
MAX_BODY_BYTES=262144           # 256 KB request body limit
SESSION_TTL_MS=86400000         # 24 hours

# Firebase FCM — Push Notifications
# 1. Go to Firebase Console → your project → Project Settings → Service Accounts
# 2. Click "Generate new private key" → download the JSON file
# 3. Copy the values below from that JSON file
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Paste the private_key value — replace actual newlines with \n
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n"

# ─── SMS OTP Delivery ────────────────────────────────────────────────────────
# Choose provider: twilio | msg91 | 2factor | console (console = dev mode, logs to terminal)
SMS_PROVIDER=console

# Twilio (primary — recommended for global numbers)
# Sign up: https://www.twilio.com/try-twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# MSG91 (Indian SMS provider — good for India)
# Sign up: https://msg91.com/
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_SENDER_ID=GOAPP
MSG91_TEMPLATE_ID=your_template_id

# 2Factor (Indian OTP provider)
# Sign up: https://2factor.in/
TWOFACTOR_API_KEY=your_2factor_api_key

# ─── Coins / Wallet ──────────────────────────────────────────────────────────
COIN_INR_VALUE=0.10       # 1 coin = ₹0.10 discount
COINS_PER_INR_EARN=10     # Earn 1 coin per ₹10 of ride fare
MIN_REDEEM_COINS=10       # Minimum coins needed to redeem
MAX_REDEEM_PCT=0.20       # Max 20% of fare can be discounted via coins
